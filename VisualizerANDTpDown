-- Speed Visualizer | mxrixn (Simplified)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer
local billboard = nil
local speedLbl = nil
local isOn = false

-- ==================== GUI ====================
local gui = Instance.new("ScreenGui")
gui.Name = "SpeedViz_mxrixn"
gui.ResetOnSpawn = false
gui.DisplayOrder = 999
gui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local main = Instance.new("Frame")
main.Size = UDim2.new(0, 220, 0, 145)
main.Position = UDim2.new(0, 50, 0, 50)
main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
main.BackgroundTransparency = 0.45
main.BorderSizePixel = 0
main.Active = true
main.Parent = gui

Instance.new("UICorner", main).CornerRadius = UDim.new(0, 10)

local stroke = Instance.new("UIStroke", main)
stroke.Color = Color3.fromRGB(255, 100, 150)
stroke.Thickness = 2

local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1, 0, 0, 32)
title.BackgroundTransparency = 1
title.Text = "Speed Visualizer | mxrixn"
title.TextColor3 = Color3.fromRGB(255, 100, 150)
title.Font = Enum.Font.GothamBold
title.TextSize = 14
title.Parent = main

-- Drag
local dragging
title.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        local startPos = main.Position
        local startMouse = inp.Position
        local conn
        conn = UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
                local delta = input.Position - startMouse
                main.Position = UDim2.new(0, startPos.X.Offset + delta.X, 0, startPos.Y.Offset + delta.Y)
            end
        end)
        inp.Changed:Connect(function()
            if inp.UserInputState == Enum.UserInputState.End then
                dragging = false
                if conn then conn:Disconnect() end
            end
        end)
    end
end)

-- Speed Button
local toggleBtn = Instance.new("TextButton", main)
toggleBtn.Size = UDim2.new(0.9, 0, 0, 38)
toggleBtn.Position = UDim2.new(0.05, 0, 0, 45)
toggleBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
toggleBtn.BackgroundTransparency = 0.5
toggleBtn.Text = "Speed VISUAL : OFF"
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.TextSize = 13
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 8)

toggleBtn.MouseButton1Click:Connect(function()
    isOn = not isOn
    if isOn then
        toggleBtn.Text = "Speed VISUAL : ON"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 100)
        enableSpeedViz()
    else
        toggleBtn.Text = "Speed VISUAL : OFF"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        disableSpeedViz()
    end
end)

-- TP Down Button
local tpBtn = Instance.new("TextButton", main)
tpBtn.Size = UDim2.new(0.9, 0, 0, 38)
tpBtn.Position = UDim2.new(0.05, 0, 0, 92)
tpBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
tpBtn.BackgroundTransparency = 0.5
tpBtn.Text = "TP DOWN"
tpBtn.TextColor3 = Color3.fromRGB(255, 100, 150)
tpBtn.Font = Enum.Font.GothamBold
tpBtn.TextSize = 13
Instance.new("UICorner", tpBtn).CornerRadius = UDim.new(0, 8)

tpBtn.MouseButton1Click:Connect(function()
    tpBtn.BackgroundColor3 = Color3.fromRGB(120, 0, 0)
    task.delay(0.2, function() tpBtn.BackgroundColor3 = Color3.fromRGB(30,30,30) end)
    teleportDown()
end)

-- ==================== FUNCTIONS ====================

function enableSpeedViz()
    local char = LocalPlayer.Character
    if not char then return end
    local head = char:FindFirstChild("Head")
    if not head then return end

    if billboard then billboard:Destroy() end

    billboard = Instance.new("BillboardGui")
    billboard.Adornee = head
    billboard.Size = UDim2.new(0, 170, 0, 38)
    billboard.StudsOffset = Vector3.new(0, 3.8, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = head

    speedLbl = Instance.new("TextLabel", billboard)
    speedLbl.Size = UDim2.new(1,0,1,0)
    speedLbl.BackgroundTransparency = 1
    speedLbl.TextColor3 = Color3.fromRGB(255, 105, 180)
    speedLbl.Font = Enum.Font.GothamBold
    speedLbl.TextScaled = true
    speedLbl.TextStrokeTransparency = 0.5
end

function disableSpeedViz()
    if billboard then
        billboard:Destroy()
        billboard = nil
    end
end

function teleportDown()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local ray = RaycastParams.new()
    ray.FilterDescendantsInstances = {char}
    ray.FilterType = Enum.RaycastFilterType.Exclude

    local result = workspace:Raycast(hrp.Position, Vector3.new(0, -1000, 0), ray)
    if result then
        local hum = char:FindFirstChildOfClass("Humanoid")
        local offset = (hum and hum.HipHeight or 2) + (hrp.Size.Y / 2) + 0.3
        hrp.CFrame = CFrame.new(hrp.Position.X, result.Position.Y + offset, hrp.Position.Z)
    end
end

-- Speed Update
RunService.RenderStepped:Connect(function()
    if not isOn or not speedLbl then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        local speed = (hrp.AssemblyLinearVelocity * Vector3.new(1,0,1)).Magnitude
        speedLbl.Text = string.format("Speed: %.1f", speed)
    end
end)

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1)
    if isOn then
        disableSpeedViz()
        enableSpeedViz()
    end
end)
