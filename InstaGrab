-- ====================== CORE FUNCTIONS ======================
local function getHRP()
    if hrpCache and hrpCache.Parent then return hrpCache end
    local char = player.Character
    if char then hrpCache = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") end
    return hrpCache
end

local function rebuildAnimalCache()
    allAnimalsCache = {}
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return end
    for _, plot in ipairs(plots:GetChildren()) do
        local podiums = plot:FindFirstChild("AnimalPodiums")
        if podiums then
            for _, podium in ipairs(podiums:GetChildren()) do
                local base = podium:FindFirstChild("Base")
                local spawn = base and base:FindFirstChild("Spawn")
                local attach = spawn and spawn:FindFirstChild("PromptAttachment")
                local prompt = attach and attach:FindFirstChildOfClass("ProximityPrompt")
                if prompt then
                    table.insert(allAnimalsCache, {
                        worldPosition = podium:GetPivot().Position,
                        prompt = prompt
                    })
                end
            end
        end
    end
end

local function getNearestAnimal()
    local hrp = getHRP()
    if not hrp then return nil end
    local pos = hrp.Position
    local nearest, minDist = nil, math.huge
    for _, a in ipairs(allAnimalsCache) do
        if a.prompt and a.prompt.Parent then
            local dist = (pos - a.worldPosition).Magnitude
            if dist < minDist and dist <= GRAB_RADIUS then
                minDist = dist
                nearest = a
            end
        end
    end
    return nearest
end

local function trySteal(prompt)
    if not prompt or not prompt.Parent or (os.clock() - LastActionTime) < BASE_COOLDOWN then return end
    LastActionTime = os.clock()

    pcall(function()
        prompt.HoldDuration = 0
        prompt:InputHoldBegin()
        task.wait(STEAL_DELAY)
        prompt:InputHoldEnd()
        task.wait(STEAL_DELAY)
        prompt:InputTrigger()
    end)
end

