-- ====================== SAVE & RESTORE ======================
local originalLighting = {}
local originalDescendants = {}

local function saveOriginalState()
    if next(originalLighting) ~= nil then return end
    originalLighting = {
        GlobalShadows = Lighting.GlobalShadows,
        FogEnd = Lighting.FogEnd,
        Brightness = Lighting.Brightness,
        ClockTime = Lighting.ClockTime,
    }
end

local function restoreOriginalState()
    if next(originalLighting) == nil then return end
    Lighting.GlobalShadows = originalLighting.GlobalShadows or true
    Lighting.FogEnd = originalLighting.FogEnd or 100000
    Lighting.Brightness = originalLighting.Brightness or 1
    Lighting.ClockTime = originalLighting.ClockTime or 14

    for _, data in ipairs(originalDescendants) do
        pcall(function()
            if data.obj then
                if data.Material then data.obj.Material = data.Material end
                if data.CastShadow ~= nil then data.obj.CastShadow = data.CastShadow end
            end
        end)
    end
    originalDescendants = {}
end

local function applyAntiLag(enabled)
    saveOriginalState()
    if enabled then
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 10000000
        Lighting.Brightness = 1.3
        Lighting.ClockTime = 12

        for _, v in ipairs(Workspace:GetDescendants()) do
            if (v:IsA("BasePart") or v:IsA("MeshPart")) and not v:FindFirstAncestorWhichIsA("Accessory") then
                table.insert(originalDescendants, {obj = v, Material = v.Material, CastShadow = v.CastShadow})
                v.Material = Enum.Material.Plastic
                v.CastShadow = false
            end
        end
    else
        restoreOriginalState()
    end
end

local function applyUltraMode(enabled)
    saveOriginalState()
    if enabled then
        applyAntiLag(true)
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then
                table.insert(originalDescendants, {obj = v, Enabled = v.Enabled})
                v.Enabled = false
            end
        end
    else
        restoreOriginalState()
    end
end

-- ====================== PLAYER ESP ======================
local function createPlayerESP(targetPlayer)
    if targetPlayer == player then return end
    if espHighlights[targetPlayer] then return end

    local character = targetPlayer.Character
    if not character then return end

    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- Highlight
    local highlight = Instance.new("Highlight")
    highlight.Name = "GalaxyESP"
    highlight.FillColor = Color3.fromRGB(255, 100, 200)
    highlight.OutlineColor = Color3.fromRGB(180, 80, 255)
    highlight.FillTransparency = 0.7
    highlight.OutlineTransparency = 0
    highlight.Adornee = character
    highlight.Parent = character

    -- Username above head
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "GalaxyNameESP"
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.LightInfluence = 0
    billboard.Adornee = root
    billboard.Parent = character

    local textLabel = Instance.new("TextLabel", billboard)
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = targetPlayer.Name
    textLabel.TextColor3 = Color3.fromRGB(255, 220, 255)
    textLabel.TextStrokeTransparency = 0.4
    textLabel.TextStrokeColor3 = Color3.fromRGB(80, 0, 120)
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextSize = 14
    textLabel.TextScaled = true

    espHighlights[targetPlayer] = {highlight = highlight, billboard = billboard}
end

local function updatePlayerESP()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            createPlayerESP(plr)
        end
    end
end

local function togglePlayerESP(enabled)
    playerESPEnabled = enabled
    if not enabled then
        for _, data in pairs(espHighlights) do
            if data.highlight then data.highlight:Destroy() end
            if data.billboard then data.billboard:Destroy() end
        end
        espHighlights = {}
        return
    end
    updatePlayerESP()
end

